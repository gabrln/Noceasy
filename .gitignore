# ===== temporários / editores =====
*~
*.swp
*.swo
*.bak
*.save
*.tmp

# ===== caches =====
.cache/
**/.cache/
**/Cache/
**/cache/

# ===== logs =====
*.log

# ===== segredos (segurança) =====
.env
*.key
*.pem
id_rsa
id_ed25519
known_hosts

# ===== configurações locais ignoradas =====
.config/rofi/

# ===== Neovim generated =====
.config/nvim/lua/matugen.lua

# ===== Kitty generated =====
.config/kitty/current-theme.conf
.config/kitty/themes/

# ===== Mango generated =====
.config/mango/noctalia.conf

# ===== Niri generated =====
.config/niri/noctalia.kdl

# ===== GTK generated =====
.config/gtk-3.0/*
!.config/gtk-3.0/settings.ini
.config/gtk-4.0/*
!.config/gtk-4.0/settings.ini

# ===== OpenCode generated =====
.config/opencode/node_modules/
.config/opencode/package.json
.config/opencode/package-lock.json

# ===== Zsh modular configuration =====
.config/zsh/plugins/
.config/zsh/.zcompdump*
.config/zsh/*.zwc

# ===== Python cache =====
__pycache__/
*.pyc
