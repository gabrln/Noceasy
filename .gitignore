# ===== temporários / editores =====
*~
*.swp
*.swo
*.bak
*.save
*.tmp

# ===== caches =====
.cache/
**/.cache/
**/Cache/
**/cache/

# ===== logs =====
*.log

# ===== segredos (segurança) =====
.env
*.key
*.pem
id_rsa
id_ed25519
known_hosts

# ===== configurações locais ignoradas =====
.config/nvim/
.config/rofi/
.config/noctalia/

# ===== Zsh modular configuration =====
.config/zsh/plugins/
.config/zsh/.zcompdump*
.config/zsh/*.zwc

# ===== Python cache =====
__pycache__/
*.pyc
