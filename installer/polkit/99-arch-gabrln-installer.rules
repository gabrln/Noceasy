/* Arch-gabrln installer — polkit rule
 *
 * Permite que REAL_USER invoque os helpers do framework via pkexec
 * sem precisar de autenticação interativa. Esta regra é instalada
 * pelo installer em /etc/polkit-1/rules.d/ e removida no EXIT.
 *
 * Para produção final (fora do contexto de install), a regra deve
 * ser removida — ela só existe para automatizar o install.
 */
polkit.addRule(function(action, subject) {
    if (action.id == "org.archlinux.pkexec.gabrln" &&
        subject.user == "@REAL_USER@" &&
        subject.local && subject.active) {
        return polkit.Result.YES;
    }
});
