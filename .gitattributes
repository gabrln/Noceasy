# Força line endings LF em arquivos executados no Linux
* text=auto
*.sh text eol=lf
*.bash text eol=lf
*.lua text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.desktop text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binários
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
