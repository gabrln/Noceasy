#!/usr/bin/env bash
# noceasy-helper - Helper binary invoked via pkexec by polkit
#
# Lives at /usr/local/bin/ and is referenced by the polkit policy
# (org.archlinux.pkexec.noceasy). When the user runs
# `pkexec noceasy-helper <subcommand>`, polkit checks the rule in
# /etc/polkit-1/rules.d/99-noceasy-installer.rules; if the subject
# is REAL_USER and the rule returns YES, this script runs as root
# without a password prompt.
#
# Subcommands:
#   refresh-icon-cache      Update gtk-update-icon-cache
#   update-hyprpm           Run hyprpm update -v
#   enable-service <svc>    systemctl enable <svc>
#   restart-user-service    systemctl --user restart
#   set-shell <user>        chsh -s /usr/bin/zsh <user>
#
# IMPORTANT: This helper is designed to be invoked ONLY by the
# user configured in REAL_USER. The polkit policy enforces this
# via subject.user check.

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "ERROR: noceasy-helper must be invoked via pkexec." >&2
  exit 1
fi

log() { echo "[noceasy-helper] $*"; }
die() { echo "ERROR: $*" >&2; exit "${2:-1}"; }

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  refresh-icon-cache)
    log "Updating icon cache..."
    for dir in /usr/share/icons/*/ /home/*/.local/share/icons/*/; do
      [[ -d "$dir" ]] || continue
      gtk-update-icon-cache -f -t "$dir" 2>/dev/null || true
    done
    log "Cache updated."
    ;;

  update-hyprpm)
    log "Updating hyprpm..."
    command -v hyprpm >/dev/null || die "hyprpm not installed."
    hyprpm update -v
    ;;

  enable-service)
    svc="${1:-}"
    [[ -n "$svc" ]] || die "Usage: noceasy-helper enable-service <unit>"
    log "Enabling $svc..."
    systemctl enable "$svc"
    ;;

  restart-user-service)
    svc="${1:-}"
    [[ -n "$svc" ]] || die "Usage: noceasy-helper restart-user-service <unit>"
    log "Restarting user service $svc..."
    _uid=$(stat -c %u /run/user/* 2>/dev/null | head -1 || true)
    if [[ -n "$_uid" ]]; then
      XDG_RUNTIME_DIR="/run/user/$_uid" systemctl --user restart "$svc" || true
    fi
    ;;

  set-shell)
    user="${1:-}"
    shell="${2:-/usr/bin/zsh}"
    [[ -n "$user" ]] || die "Usage: noceasy-helper set-shell <user> [shell]"
    log "Changing shell of $user to $shell..."
    chsh -s "$shell" "$user"
    ;;

  help|--help|-h|"")
    cat <<EOF
noceasy-helper — helper invoked via pkexec by the polkit policy

Usage: pkexec noceasy-helper <command> [args]

Commands:
  refresh-icon-cache           Update system icon cache
  update-hyprpm                Run hyprpm update -v
  enable-service <unit>        Enable a systemd unit
  restart-user-service <unit>  Restart a user service
  set-shell <user> [shell]     Change default shell
  help                         Show this message
EOF
    ;;

  *)
    die "Unknown command: $cmd. Use 'noceasy-helper help'." 2
    ;;
esac
