#!/usr/bin/env bash
# gabrln - Entrypoint principal do framework de instalação Arch-gabrln

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_DIR=$(cd "$SCRIPT_DIR/.." && pwd)
INSTALLER_DIR="$REPO_DIR/installer"
CONFIG_FILE="$INSTALLER_DIR/config.toml"
MODULES_DIR="$INSTALLER_DIR/modules"
MANIFESTS_DIR="$INSTALLER_DIR/manifests"

export REPO_DIR INSTALLER_DIR CONFIG_FILE MODULES_DIR MANIFESTS_DIR

# shellcheck source=SCRIPTDIR/lib/logger.sh
source "$INSTALLER_DIR/lib/logger.sh"
# shellcheck source=SCRIPTDIR/lib/utils.sh
source "$INSTALLER_DIR/lib/utils.sh"
# shellcheck source=SCRIPTDIR/lib/errors.sh
source "$INSTALLER_DIR/lib/errors.sh"
# shellcheck source=SCRIPTDIR/lib/state.sh
source "$INSTALLER_DIR/lib/state.sh"
# shellcheck source=SCRIPTDIR/lib/backup.sh
source "$INSTALLER_DIR/lib/backup.sh"
# shellcheck source=SCRIPTDIR/lib/progress.sh
source "$INSTALLER_DIR/lib/progress.sh"

# Garante que LOGS_DIR seja absoluto
LOGS_DIR="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.logs_dir" "installer/logs")"
log_init "$LOGS_DIR"

usage() {
  cat <<EOF
Uso: gabrln <comando> [opções]

Comandos:
  install   Executa a instalação completa (módulos 00-16)
  update    Atualiza dotfiles, AUR -git e manifesto hyprpm
  repair    Reaplica configurações divergentes
  backup    Cria snapshot manual das configurações
  rollback  Restaura o snapshot mais recente
  doctor    Verifica o estado atual sem modificar nada
  help      Mostra esta mensagem

Opções comuns:
  --gaming  Habilita pacotes com tag gaming (quando suportado)
  --force   Ignora estado e reexecuta módulos

EOF
}

# Detecta flags globais e remove-as dos argumentos.
GAMING=false
FORCE=false
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --gaming)
      GAMING=true
      shift
      ;;
    --force)
      FORCE=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      log_error "Opção desconhecida: $1"
      usage
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}"

COMMAND="${1:-help}"
shift 2>/dev/null || true

export GAMING FORCE

# Executa um módulo individual se ele existir.
# Uso: run_module <nome> <manifesto>
run_module() {
  local module="$1"
  local manifest="${2:-}"
  local module_path="$MODULES_DIR/$module.sh"

  if [[ ! -f "$module_path" ]]; then
    log_warn "Módulo $module não encontrado em $module_path. Pulando."
    return 0
  fi

  if [[ "$FORCE" != true ]] && [[ -n "$manifest" ]] && state_is_up_to_date "$module" "$manifest"; then
    log_info "Módulo $module já está atualizado. Pulando."
    return 0
  fi

  log_step "Executando módulo $module"
  # shellcheck source=/dev/null
  source "$module_path"

  if [[ -n "$manifest" ]]; then
    state_mark_done "$module" "$manifest"
  else
    state_mark_done "$module"
  fi
}

# Inicializa diretórios de estado e backup.
init_framework() {
  local state_dir backups_dir
  state_dir="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.state_dir" "installer/state")"
  backups_dir="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.backups_dir" "installer/state/backups")"

  state_init "$state_dir"
  backup_init "$backups_dir"
}

# Coleta caminhos para backup a partir do manifesto de dotfiles.
_collect_backup_paths() {
  local paths=()

  while IFS= read -r cfg; do
    [[ -n "$cfg" ]] && paths+=("$USER_HOME/.config/$cfg")
  done < <(python3 -c '
import sys, tomllib
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)
for c in data.get("directories", {}).get("configs", []):
    print(c)
' "$MANIFESTS_DIR/dotfiles.toml")

  paths+=("$USER_HOME/.config/zsh")

  while IFS= read -r f; do
    [[ -n "$f" ]] && paths+=("$f")
  done < <(python3 -c '
import sys, tomllib, os
file, home = sys.argv[1], sys.argv[2]
with open(file, "rb") as f:
    data = tomllib.load(f)
for src, dst in data.get("files", {}).items():
    expanded = os.path.expandvars(dst)
    if expanded.startswith("~"):
        expanded = home + expanded[1:]
    print(expanded)
' "$MANIFESTS_DIR/dotfiles.toml" "$USER_HOME")

  paths+=("/etc/greetd")
  paths+=("/etc/pam.d/greetd")

  printf '%s\n' "${paths[@]}"
}

# Instalação completa (módulos 00-16).
cmd_install() {
  log_step "Iniciando instalação Arch-gabrln"
  log_info "REPO_DIR: $REPO_DIR"
  log_info "GAMING: $GAMING | FORCE: $FORCE"

  setup_traps
  detect_real_user
  setup_temp_sudoers
  init_framework

  run_module "00-preflight"
  run_module "01-backup" "$MANIFESTS_DIR/dotfiles.toml"
  run_module "02-pacman-bootstrap"
  run_module "03-shelly-official" "$MANIFESTS_DIR/packages.toml"
  run_module "04-shelly-aur" "$MANIFESTS_DIR/aur.toml"
  run_module "05-shelly-flatpak" "$MANIFESTS_DIR/flatpak.toml"
  run_module "06-curl-tools" "$MANIFESTS_DIR/curl-tools.toml"
  run_module "07-shell" "$MANIFESTS_DIR/zsh-plugins.toml"
  run_module "08-dotfiles" "$MANIFESTS_DIR/dotfiles.toml"
  run_module "09-hyprland-env"
  run_module "10-greeter"
  run_module "11-keyring"
  run_module "12-hyprpm-manifest" "$MANIFESTS_DIR/hyprpm.toml"
  run_module "13-wallpapers" "$MANIFESTS_DIR/wallpapers.toml"
  run_module "14-icons-cursors-fonts"
  run_module "15-system-tweaks"
  run_module "16-services" "$MANIFESTS_DIR/services.toml"

  log_success "Instalação completa concluída."
}

# Atualização seletiva: dotfiles, AUR -git, hyprpm manifesto.
cmd_update() {
  log_step "Iniciando atualização Arch-gabrln"
  log_info "GAMING: $GAMING | FORCE: $FORCE"

  setup_traps
  detect_real_user
  setup_temp_sudoers
  init_framework

  log_info "Atualizando repositório local..."
  run_as_user "git -C '$REPO_DIR' pull"

  run_module "08-dotfiles" "$MANIFESTS_DIR/dotfiles.toml"
  run_module "04-shelly-aur" "$MANIFESTS_DIR/aur.toml"
  run_module "12-hyprpm-manifest" "$MANIFESTS_DIR/hyprpm.toml"

  log_success "Atualização concluída."
}

# Reparo: reaplica configurações de login, serviços e manifesto hyprpm.
cmd_repair() {
  log_step "Iniciando reparo Arch-gabrln"
  log_info "GAMING: $GAMING | FORCE: $FORCE"

  setup_traps
  detect_real_user
  setup_temp_sudoers
  init_framework

  run_module "10-greeter"
  run_module "11-keyring"
  run_module "12-hyprpm-manifest" "$MANIFESTS_DIR/hyprpm.toml"
  run_module "16-services" "$MANIFESTS_DIR/services.toml"

  log_info "Reparo concluído. Se o Alt+Tab ainda não funcionar, execute manualmente no Hyprland:"
  log_info "  hyprpm update && hyprpm add https://github.com/yayuuu/hyprland-scroll-overview.git && hyprpm enable scrolloverview"
  log_success "Reparo finalizado."
}

# Backup manual.
cmd_backup() {
  log_step "Iniciando backup manual"

  setup_traps
  detect_real_user
  init_framework

  mapfile -t paths < <(_collect_backup_paths)
  backup_name=$(backup_create "manual" "${paths[@]}")
  log_success "Backup manual criado: $backup_name"
}

# Rollback: restaura snapshot mais recente.
cmd_rollback() {
  log_step "Iniciando rollback"

  setup_traps
  detect_real_user
  init_framework

  backup_restore "pre-install" || backup_restore "manual"
  log_success "Rollback finalizado."
}

# Doctor: diagnóstico somente leitura.
cmd_doctor() {
  log_step "Iniciando diagnóstico Arch-gabrln"

  # Não requer root, mas utiliza REAL_USER/USER_HOME se disponível
  if [[ "${EUID:-}" -eq 0 && -n "${SUDO_USER:-}" ]]; then
    REAL_USER="$SUDO_USER"
    USER_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)
  else
    REAL_USER="${USER:-$(whoami)}"
    USER_HOME="${HOME:-$(cd ~ && pwd)}"
  fi

  local issues=0

  log_info "Verificando dotfiles..."
  while IFS= read -r cfg; do
    [[ -z "$cfg" ]] && continue
    if [[ ! -e "$USER_HOME/.config/$cfg" ]]; then
      log_warn "  → ausente: ~/.config/$cfg"
      issues=$((issues + 1))
    fi
  done < <(python3 -c '
import sys, tomllib
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)
for c in data.get("directories", {}).get("configs", []):
    print(c)
' "$MANIFESTS_DIR/dotfiles.toml")

  if [[ ! -e "$USER_HOME/.config/zsh" ]]; then
    log_warn "  → ausente: ~/.config/zsh"
    issues=$((issues + 1))
  fi

  log_info "Verificando shell padrão..."
  local current_shell=""
  if is_command getent; then
    current_shell=$(getent passwd "$REAL_USER" | cut -d: -f7)
  elif [[ -n "${SHELL:-}" ]]; then
    current_shell="$SHELL"
  fi
  if [[ -n "$current_shell" && "$current_shell" != "/usr/bin/zsh" ]]; then
    log_warn "  → shell padrão é $current_shell (esperado /usr/bin/zsh)"
    issues=$((issues + 1))
  fi

  log_info "Verificando plugins do Zsh..."
  while IFS='|' read -r name entry; do
    [[ -z "$name" ]] && continue
    if [[ ! -e "$USER_HOME/.config/zsh/plugins/$name/$entry" ]]; then
      log_warn "  → ausente: plugin $name"
      issues=$((issues + 1))
    fi
  done < <(python3 -c '
import sys, tomllib
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)
for p in data.get("plugins", []):
    print(p["name"] + "|" + p["entry"])
' "$MANIFESTS_DIR/zsh-plugins.toml")

  log_info "Verificando serviços systemd..."
  while IFS= read -r svc; do
    [[ -z "$svc" ]] && continue
    if ! systemctl is-enabled "$svc" &>/dev/null; then
      log_warn "  → não habilitado: $svc"
      issues=$((issues + 1))
    fi
  done < <(python3 -c '
import sys, tomllib
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)
for s in data.get("services", []):
    print(s["name"])
' "$MANIFESTS_DIR/services.toml")

  if [[ $issues -eq 0 ]]; then
    log_success "Nenhuma divergência encontrada."
  else
    log_warn "Divergências encontradas: $issues. Use 'gabrln repair' para corrigir."
  fi
}

case "$COMMAND" in
  install)
    cmd_install
    ;;
  update)
    cmd_update
    ;;
  repair)
    cmd_repair
    ;;
  backup)
    cmd_backup
    ;;
  rollback)
    cmd_rollback
    ;;
  doctor)
    cmd_doctor
    ;;
  help|-h|--help)
    usage
    exit 0
    ;;
  *)
    log_error "Comando desconhecido: $COMMAND"
    usage
    exit 1
    ;;
esac

log_success "gabrln finalizado com sucesso."
